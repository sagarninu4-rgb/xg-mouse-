{
  "name": "xg-mouse-monorepo",
  "version": "1.0.0",
  "description": "Professional 3D Gaming E-commerce Platform",
  "main": "server.js",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd apps/web && npm install && cd ../api && npm install",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd apps/web && npm run dev",
    "dev:backend": "cd apps/api && npm run dev",
    "build:frontend": "cd apps/web && npm run build",
    "start:backend": "cd apps/api && npm run start",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.0"
  },
  "workspaces": [
    "apps/web",
    "apps/api"
  ]
}